% bplan-begruendung.cls
% Universal document class for German B-Plan Begründung.
% Encapsulates the structural domain (scrreprt + KOMA conventions,
% German language, siunitx number formatting, Roman/Arabic page
% numbering split, section-number flattening, Projektdaten macro
% framework).
%
% NOT included here: geometry, header content, font choices, TOC
% styling, color theme, office identity, hyphenation hints. Those
% are office-specific and live in office-style.sty (Layer 2 of the
% template stack).
%
% NOT included here: per-project values (\Gemeinde, \BPlanNr, etc.).
% Those live in Projektdaten.tex (Layer 3).
%
% Usage:
%   \documentclass{bplan-begruendung}
%   \usepackage{office-style}     % office aesthetic + identity
%   \input{office-identity}       % auto-generated from office-config
%   \input{Projektdaten}          % per-project metadata
%   \begin{document}
%   ...
%   \end{document}

\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{bplan-begruendung}[2026/04/28 v0.1 B-Plan Begruendung]

% ---- Pass options through to scrreprt --------------------------------
\DeclareOption*{\PassOptionsToClass{\CurrentOption}{scrreprt}}
\ProcessOptions\relax

% ---- Base class with sensible KOMA defaults -------------------------
\LoadClass[
  12pt,
  a4paper,
  parskip=half,
  bibliography=totoc,
  captions=tableheading,
  toc=listof
]{scrreprt}

% ---- Encoding & language --------------------------------------------
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage[ngerman]{babel}

% ---- Hyphenation tuning (universal defaults) ------------------------
% Office may override or extend in office-style.sty.
\RequirePackage{hyphenat}
\tolerance=1500
\emergencystretch=3em
\hyphenpenalty=50
\exhyphenpenalty=50
\hbadness=10000

% ---- Number formatting (German conventions) -------------------------
\RequirePackage{siunitx}
\sisetup{
  output-decimal-marker={,},
  group-separator={.},
  group-minimum-digits=4
}
\providecommand{\formatnumber}[1]{\num[round-mode=places,round-precision=0]{#1}}

% ---- Header layer (loaded; not configured here) ---------------------
% Office-style.sty configures \ihead/\ohead/pagestyles.
\RequirePackage[automark]{scrlayer-scrpage}

% ---- Roman -> Arabic page numbering helpers -------------------------
\providecommand{\startroman}{%
  \cleardoublepage
  \pagenumbering{Roman}
  \setcounter{page}{1}%
}
\providecommand{\startarabic}{%
  \cleardoublepage
  \pagenumbering{arabic}
  \setcounter{page}{1}%
}

% ---- Section number flattening --------------------------------------
% scrreprt would otherwise prefix all numbering with chapters.
% B-Plan Begründungen use sections at top level.
\renewcommand{\thesection}{\arabic{section}}
\renewcommand{\thesubsection}{\thesection.\arabic{subsection}}
\renewcommand{\thesubsubsection}{\thesubsection.\arabic{subsubsection}}

% ---- Project metadata framework (defaults) --------------------------
% These are placeholders. Projektdaten.tex MUST override every one
% with concrete values before publication. Placeholder values use
% the SHOUTED-UPPERCASE pattern (---FIELD---) to make unfilled
% fields glaringly visible in compile output.
\providecommand{\Gemeinde}{---GEMEINDE---}
\providecommand{\Stadt}{---STADT---}
\providecommand{\Gemarkung}{---GEMARKUNG---}
\providecommand{\Ortsteil}{---ORTSTEIL---}
\providecommand{\Landkreis}{---LANDKREIS---}
\providecommand{\Bundesland}{---BUNDESLAND---}
\providecommand{\BPlanAbrv}{B-Plan}
\providecommand{\BPlanNr}{---N---}
\providecommand{\BPlanName}{---BPLAN-NAME---}
\providecommand{\BPlan}{---BPLAN-PROSE-LOWERCASE---}
\providecommand{\BPlanTyp}{---BPLAN-PROSE-CAPITALIZED---}
\providecommand{\GeltungsbereichHa}{---HA---}
\providecommand{\GeltungsbereichHaSolar}{---HA---}
\providecommand{\Planungsregion}{---PLANUNGSREGION---}

% ---- Office identity macro defaults ---------------------------------
% Auto-generated by the backend into office-identity.tex from
% office-config. Defaulted here so a missing office-identity.tex
% does not crash the compile.
\providecommand{\OfficeName}{---OFFICE-NAME---}
\providecommand{\OfficeShort}{---OFFICE-SHORT---}
\providecommand{\OfficeAddressLines}{---OFFICE-ADDRESS---}
\providecommand{\OfficePhone}{}
\providecommand{\OfficeEmail}{}
\providecommand{\OfficeWeb}{}
\providecommand{\OfficeSignatureBlock}{---OFFICE-SIGNATURE---}
\providecommand{\OfficeSigner}{---OFFICE-SIGNER---}

\endinput
