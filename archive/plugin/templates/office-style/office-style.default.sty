% office-style.default.sty
% Default office-style template shipped with the app. Setup-office
% copies this to <office_state_root>/templates/office-style.sty on
% first deployment. Each office customizes its copy from there.
%
% This default provides minimal sensible aesthetics so a fresh
% deployment compiles without further authoring. It does NOT carry
% any office-specific identity.
%
% Layer 2 of the 3-layer template stack:
%   Layer 1 — App: bplan-{begruendung,festsetzungen}.cls (universal
%             structural domain). Loaded via \documentclass.
%   Layer 2 — Office: this file. Loaded via \usepackage{office-style}.
%   Layer 3 — Project: Projektdaten.tex (per-project metadata).
%             Loaded via \input{Projektdaten}.
%
% Office-identity macros are auto-generated by the backend's
% compile_latex helper into office-identity.tex from the office-config
% identity: section. office-identity.tex is loaded after this file.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{office-style}[2026/04/28 v0.1 Default office-style]

% ---- Geometry — sensible A4 defaults ---------------------------------
% Festsetzungen ignores this (it sets infinite-page geometry in its
% class). Begründung uses these values for its multi-page layout.
\@ifclassloaded{bplan-begruendung}{%
  \RequirePackage[
    a4paper,
    left=25mm, right=25mm,
    top=30mm, bottom=25mm,
    headheight=30pt,
    marginparwidth=0pt
  ]{geometry}
}{}

% ---- Header layout (Begründung only) --------------------------------
\@ifclassloaded{bplan-begruendung}{%
  \clearpairofpagestyles
  \ihead{\small\parbox[t]{0.45\textwidth}{Gemeinde \Gemeinde{} \\
         \BPlanTyp{} \BPlan{}}}
  \ohead{\small Begründung \\ \small Seite \thepage}
  %
  % Custom 'tocstyle' so prelim pages keep the same header.
  \newpairofpagestyles[scrheadings]{tocstyle}{
    \ihead{\small\parbox[t]{0.45\textwidth}{Gemeinde \Gemeinde{} \\
           \BPlanTyp{} \BPlan{}}}
    \ohead{\small Begründung \\ \small Seite \thepage}
  }
  \renewcommand*{\chapterpagestyle}{tocstyle}
}{}

% ---- Heading fonts (Begründung) -------------------------------------
\@ifclassloaded{bplan-begruendung}{%
  \addtokomafont{section}{\normalfont\Large\bfseries}
  \addtokomafont{subsection}{\normalfont\large\bfseries}
  \addtokomafont{subsubsection}{\normalfont\normalsize\bfseries}
}{}

% ---- TOC styling (Begründung) ---------------------------------------
\@ifclassloaded{bplan-begruendung}{%
  \RequirePackage{tocbasic}
  \setcounter{tocdepth}{3}
  \RedeclareSectionCommands[
    tocdynnumwidth,
    toclinefill=\TOCLineLeaderFill,
    tocraggedpagenumber=true
  ]{section,subsection,subsubsection}
  \DeclareTOCStyleEntry[indent=0pt, numwidth=2em, level=1,
                       entryformat=\normalfont]{tocline}{section}
  \DeclareTOCStyleEntry[indent=2em, numwidth=3em, level=2,
                       entryformat=\normalfont]{tocline}{subsection}
  \DeclareTOCStyleEntry[indent=5em, numwidth=4em, level=3,
                       entrynumberformat=\itshape,
                       entryformat=\normalfont\itshape]{tocline}{subsubsection}
  \DeclareTOCStyleEntry[beforeskip=1.0em plus 1pt]{tocline}{section}
  \renewcaptionname{ngerman}{\contentsname}{\MakeUppercase{Inhaltsverzeichnis}}
}{}

% ---- Hyphenation hints (universal-ish) -------------------------------
% Common German planning-bureau compound words that LaTeX otherwise
% breaks badly.
\hyphenation{%
  Na-tur-schutz-aus-fueh-rungs-ge-setz%
  Bun-des-na-tur-schutz-ge-setz%
  Lan-des-pla-nungs-ge-setz%
  Lan-des-bau-ord-nung%
  Be-bau-ungs-plan%
  Plan-zei-chen-ver-ord-nung%
  Auf-stel-lungs-be-schluss%
}

% ---- Hyperref (Begründung; for clickable TOC) ------------------------
\@ifclassloaded{bplan-begruendung}{%
  \RequirePackage[hidelinks]{hyperref}
}{}

\endinput
