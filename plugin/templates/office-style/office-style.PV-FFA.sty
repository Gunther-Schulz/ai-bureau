% ---- Hyphenation hints (PV-FFA-specific compounds) ------------------
\hyphenation{%
  Photo-vol-ta-ik-Frei-flae-chen-an-la-ge%
  Solar-park%
  Modul-rei-he%
  Auf-staen-de-rungs-grad%
  Bo-den-an-spruch%
  Anti-Re-flex-be-schich-tung%
}

\endinput
