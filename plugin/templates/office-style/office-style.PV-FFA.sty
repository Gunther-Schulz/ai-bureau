% office-style.PV-FFA.sty
% Domain-specific office-style overlay for offices working primarily on
% Photovoltaik-Freiflächenanlagen (PV-FFA) projects.
%
% Layered after office-style.default.sty when the office's
% scope.domains[] includes PV-FFA. Adds PV-FFA-conventional macros
% and figure conventions on top of the base aesthetic.
%
% setup-office offers this as a starter overlay. Offices customize
% their own copy at <office_state_root>/templates/office-style.sty
% (or as a separate office-style-PV-FFA.sty addon, if they want both
% domains active with separate aesthetics).
%
% Layer 2 (domain overlay) of the 3-layer template stack.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{office-style-PV-FFA}[2026/04/28 v0.1 PV-FFA domain overlay]

% ---- PV-FFA domain conventions --------------------------------------
% Modulreihen-Gestaltung wording, Reihenabstand notation,
% Aufständerungsgrad — typeset with consistent units.

\providecommand{\Modulreihen}{Modulreihen}
\providecommand{\Reihenabstand}[1]{Reihenabstand: #1\,m}
\providecommand{\Aufstaenderung}[1]{Aufständerungsgrad: #1\,°}

% ---- Common figure environment hints --------------------------------
