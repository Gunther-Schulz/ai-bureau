{
  "id": "generic-specialist-ws",
  "description": "Workspace fixture binding the generic-specialist stub (B6); exercises specialist instantiation + required-adapter resolution + skill registration + event subscription dispatch.",
  "composition": {
    "extensions": [
      { "id": "inprocess-substrate-ext", "version-range": ">=0.1.0" },
      { "id": "generic-shape-ext", "version-range": ">=0.1.0" },
      { "id": "mcp-server-ext", "version-range": ">=0.1.0" },
      { "id": "generic-specialist-ext", "version-range": ">=0.1.0" }
    ],
    "shape": {
      "provision": "generic-shape-ext:generic-shape",
      "version-range": ">=0.1.0"
    },
    "substrate-bindings": [
      {
        "binding-id": "primary",
        "provision": "inprocess-substrate-ext:inprocess-substrate",
        "version-range": ">=0.1.0",
        "runtime-shape": "interactive"
      }
    ],
    "actors": [
      { "id": "agent-primary", "subtype": "agent-actor", "substrate-binding": "primary" }
    ],
    "adapter-bindings": [
      {
        "binding-id": "primary-mcp",
        "provision": "mcp-server-ext:mcp-tool-adapter",
        "version-range": ">=0.1.0",
        "protocol-or-transport": "mcp-server-ext:mcp-client"
      }
    ],
    "specialist-bindings": [
      {
        "binding-id": "primary-specialist",
        "provision": "generic-specialist-ext:generic-specialist",
        "version-range": ">=0.1.0"
      }
    ]
  }
}
