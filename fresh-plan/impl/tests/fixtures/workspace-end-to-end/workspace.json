    ],
    "adapter-bindings": [
      {
        "binding-id": "primary-mcp",
        "provision": "mcp-server-ext:mcp-tool-adapter",
        "version-range": ">=0.1.0",
        "protocol-or-transport": "mcp-server-ext:mcp-client"
      },
      {
        "binding-id": "primary-direct",
        "provision": "direct-api-ext:direct-api-adapter",
        "version-range": ">=0.1.0",
        "protocol-or-transport": "direct-api-ext:direct-api"
      }
    ],
    "specialist-bindings": [
      {
        "binding-id": "primary-specialist",
        "provision": "generic-specialist-ext:generic-specialist",
        "version-range": ">=0.1.0"
      }
    ]
  }
